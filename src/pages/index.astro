---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Michael Borck</title>
  <meta name="description" content="Builder, educator, and researcher — helping people work with AI, not around it." />
  <link rel="icon" href="/favicon.svg" />
</head>
<body>

<a class="corner" href="/">borck<span class="tld">.dev</span></a>

<main>
  <div class="card">

    <h1 class="name">
      Michael<br><span class="surname">Borck</span>
    </h1>

    <div class="right-col">
      <p class="role">
        Builder, educator, and researcher at Curtin University —
        helping people work with AI, not around it.
      </p>

      <nav class="links">
        <a class="link" href="https://borck.education">
          <span class="link-label">Tools &amp; books</span>
          <span class="link-dest">borck.education</span>
          <span class="link-arrow">→</span>
        </a>
        <a class="link" href="https://teach.borck.dev">
          <span class="link-label">Teaching</span>
          <span class="link-dest">teach.borck.dev</span>
          <span class="link-arrow">→</span>
        </a>
        <a class="link" href="https://research.borck.dev">
          <span class="link-label">Research</span>
          <span class="link-dest">research.borck.dev</span>
          <span class="link-arrow">→</span>
        </a>
        <a class="link" href="https://resume.borck.dev">
          <span class="link-label">Resume</span>
          <span class="link-dest">resume.borck.dev</span>
          <span class="link-arrow">→</span>
        </a>

        <div class="divider"></div>

        <a class="link" href="mailto:michael@borck.dev">
          <span class="link-label">michael@borck.dev</span>
          <span class="link-arrow">→</span>
        </a>
      </nav>
    </div>

  </div>
</main>

<footer>
  <a href="https://github.com/michael-borck">GitHub</a>
  <span class="sep">·</span>
  <a href="https://linkedin.com/in/michaelborck">LinkedIn</a>
  <div class="spacer"></div>
  <span class="location">Perth, WA</span>
</footer>

</body>
</html>
